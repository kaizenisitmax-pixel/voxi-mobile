# VOXI Environment Variables

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Anthropic (Claude AI)
EXPO_PUBLIC_ANTHROPIC_API_KEY=your-anthropic-key-here

# Groq (Whisper STT - opsiyonel)
EXPO_PUBLIC_GROQ_API_KEY=your-groq-key-here

# Sentry (Hata Takibi - opsiyonel, production'da önerilir)
EXPO_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Netgsm (SMS - opsiyonel, Türkiye için)
EXPO_PUBLIC_NETGSM_USER=your-netgsm-username
EXPO_PUBLIC_NETGSM_PASSWORD=your-netgsm-password
